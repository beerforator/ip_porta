ly: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif;\n    min-height: 100vh;\n    display: flex;\n    flex-direction: column;\n    overflow-x: hidden;\n}\n\n/* --- АНИМИРОВАННЫЙ ФОН --- */\n.animated-background {\n    position: fixed;\n    top: 0; left: 0; width: 100vw; height: 100vh;\n    z-index: -1;\n    /* Создаем пятна света */\n    background: \n        radial-gradient(circle at 15% 50%, var(--accent-purple), transparent 40%),\n        radial-gradient(circle at 85% 30%, var(--accent-blue), transparent 40%);\n    /* Анимация перелива */\n    animation: bgPulse 15s ease-in-out infinite alternate;\n}\n\n@keyframes bgPulse {\n    0% { transform: scale(1); opacity: 0.8; }\n    50% { transform: scale(1.1); opacity: 1; }\n    100% { transform: scale(0.9); opacity: 0.7; }\n}\n\n/* --- УНИВЕРСАЛЬНЫЕ КЛАССЫ (УТИЛИТЫ) --- */\n.container {\n    max-width: 1280px;\n    margin: 0 auto;\n    padding: 0 var(--space-lg);\n    width: 100%;\n    box-sizing: border-box;\n}\n\n.glass-panel {\n    background: var(--glass-bg);\n    backdrop-filter: var(--glass-blur);\n    -webkit-backdrop-filter: var(--glass-blur);\n    border: 1px solid var(--glass-border);\n    border-radius: 20px;\n    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);\n}\n\n/* --- ШАПКА И ПОДВАЛ --- */\n.main-header {\n    position: sticky;\n    top: 0;\n    z-index: 100;\n    padding: var(--space-md) 0;\n    border-radius: 0 0 20px 20px;\n    border-top: none;\n}\n\n.header-content {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n}\n\n.logo {\n    font-size: 24px;\n    font-weight: bold;\n    letter-spacing: 1px;\n}\n\n.main-nav {\n    display: flex;\n    gap: var(--space-lg);\n}\n\n.main-nav a {\n    color: var(--text-main);\n    text-decoration: none;\n    font-size: 14px;\n    text-transform: uppercase;\n    letter-spacing: 0.5px;\n    transition: color 0.3s ease;\n}\n\n.main-nav a:hover {\n    color: #fff;\n    text-shadow: 0 0 8px rgba(255,255,255,0.5);\n}\n\n.page-content {\n    flex-grow: 1; /* Чтобы подвал всегда был внизу */\n    padding: var(--space-xl) 0;\n}\n```\n\n### 3. Файл `header.php`\n*Это верхняя часть нашего сайта (включает системные функции Битрикса).*\n```php\n\u003c?if(!defined(\"B_PROLOG_INCLUDED\") || B_PROLOG_INCLUDED!\u003d\u003dtrue)die();?\u003e\n\u003c!DOCTYPE html\u003e\n\u003chtml lang\u003d\"ru\"\u003e\n\u003chead\u003e\n    \u003cmeta name\u003d\"viewport\" content\u003d\"width\u003ddevice-width, initial-scale\u003d1.0\"\u003e\n    \u003ctitle\u003e\u003c?$APPLICATION-\u003eShowTitle()?\u003e\u003c/title\u003e\n    \u003c?$APPLICATION-\u003eShowHead(); // Системный вывод CSS/JS Битрикса ?\u003e\n\u003c/head\u003e\n\u003cbody\u003e\n    \u003c?$APPLICATION-\u003eShowPanel(); // Панель администратора сверху ?\u003e\n    \n    \u003cdiv class\u003d\"animated-background\"\u003e\u003c/div\u003e\n\n    \u003cheader class\u003d\"main-header glass-panel\"\u003e\n        \u003cdiv class\u003d\"container header-content\"\u003e\n            \u003cdiv class\u003d\"logo\"\u003e\n                \u003cspan style\u003d\"color: #4facfe;\"\u003eИБ\u003c/span\u003e ПОРТАЛ\n            \u003c/div\u003e\n            \u003cnav class\u003d\"main-nav\"\u003e\n                \u003ca href\u003d\"/ib-test/\"\u003eГлавная\u003c/a\u003e\n                \u003ca href\u003d\"/ib-test/news/\"\u003eНовости\u003c/a\u003e\n                \u003ca href\u003d\"/ib-test/documents/\"\u003eДокументы\u003c/a\u003e\n                \u003ca href\u003d\"/ib-test/password/\"\u003eГенератор паролей\u003c/a\u003e\n            \u003c/nav\u003e\n        \u003c/div\u003e\n    \u003c/header\u003e\n\n    \u003cmain class\u003d\"page-content\"\u003e\n        \u003cdiv class\u003d\"container\"\u003e\n            \u003c!-- Здесь будет начинаться контент конкретной страницы --\u003e\n            \u003ch1\u003e\u003c?$APPLICATION-\u003eShowTitle(false)?\u003e\u003c/h1\u003e\n```\n\n### 4. Файл `footer.php`\n*Закрывает теги и